## .NET Gitignore

# Build results
bin/
obj/

# User-specific files
*.user
*.userosscache
*.suo
*.sln.docstates

# Visual Studio Code
.vscode/
!.vscode/settings.json
!.vscode/tasks.json
!.vscode/launch.json
!.vscode/extensions.json

# JetBrains Rider
.idea/
*.sln.iml

# NuGet packages
*.nupkg
*.snupkg
packages/
!**/packages/build/
project.lock.json
project.fragment.lock.json
artifacts/

# SQLite database (contains patient data - do not commit)
*.db
*.db-shm
*.db-wal

# Sensitive configuration (API keys, SMTP credentials)
appsettings.Production.json
appsettings.Local.json

# OS files
.DS_Store
Thumbs.db

# Publish output
publish/
**/publish/

# ASP.NET Scaffolding
ScaffoldingReadMe.txt
